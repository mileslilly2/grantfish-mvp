generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  entityType  String
  mission     String
  geographies String[]
  focusAreas  String[]
  taxStatus   String
}

model Opportunity {
  id          String    @id @default(uuid())
  title       String
  description String
  agency      String
  geographies String[]
  focusAreas  String[]
  amount      Int?
  deadline    DateTime?
  createdAt   DateTime  @default(now())
}
